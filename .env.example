VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Opcional — só defina "true" se essa instância usar assinatura digital via
# ZapSign. O token de verdade fica só no secret da Edge Function zapsign-proxy
# (supabase secrets set ZAPSIGN_TOKEN=...), nunca aqui — isso aqui é só uma
# flag de liga/desliga, sem segredo nenhum.
VITE_ZAPSIGN_ENABLED=false

# Opcional — desliga a integração de cobrança via Asaas (botões "Sincronizar
# Asaas" e "Cobrança Asaas" em Financeiro) para instâncias que não usam.
# Padrão é "true" (ligado); defina "false" pra desligar.
VITE_ENABLE_ASAAS=true
